# 上級デモ用の環境変数設定
# このファイルをコピーして config.env を作成してください
# cp config.env.example config.env

# ===== 必須 =====

# Slack Webhook URL（テキスト通知用）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Pexels API Key（画像取得用）
# https://www.pexels.com/api/ で無料取得
PEXELS_API_KEY=your_pexels_api_key_here

# GCPプロジェクトID（Pub/Sub用）
GCP_PROJECT_ID=your-gcp-project-id

# 監視対象の送信者
WATCH_SENDER=namikia@cac.co.jp

# ===== オプション（ファイル添付用） =====

# Slack Bot Token（ファイルアップロード用）
# https://api.slack.com/apps でBot Token Scopesに files:write を追加
SLACK_BOT_TOKEN=xoxb-xxx-xxx-xxx

# Slack Channel ID（ファイルアップロード先）
# チャンネル名ではなくID（C0123456789形式）
SLACK_CHANNEL_ID=C0123456789
